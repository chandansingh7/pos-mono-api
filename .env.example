# Microsoft OAuth (for email receipts via Graph API)
# Required for "Connect Microsoft" in Settings to work.
# See docs/EMAIL_SETUP.md for full setup.

# Azure app Client ID and secret
MS_OAUTH_CLIENT_ID=your-azure-app-client-id
MS_OAUTH_CLIENT_SECRET=your-azure-app-client-secret

# Tenant: "common" for multitenant + personal, or your tenant ID
MS_OAUTH_TENANT=common

# Must match Redirect URI in Azure app registration (Web)
# Local: http://localhost:8080/api/company/microsoft/callback
MS_OAUTH_REDIRECT_URI=http://localhost:8080/api/company/microsoft/callback

# Where the API redirects after successful sign-in (popup closes here)
# Local: http://localhost:4200/auth/microsoft-callback
MS_OAUTH_FRONTEND_SUCCESS_URL=http://localhost:4200/auth/microsoft-callback

# Required to encrypt Microsoft refresh token in DB
# Generate: openssl rand -base64 16
SMTP_ENCRYPTION_KEY=
